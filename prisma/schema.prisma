generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooler-URL für Runtime-Queries (Vercel Postgres / Neon)
  url       = env("DATABASE_URL")
  // Direkte URL ohne Pooler – wird von Prisma für Migrations / `db push` benötigt.
  // Vercel Postgres setzt diese Variable automatisch beim Connect-Project.
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         String   @default("president") // 'treasurer' | 'president' | 'admin' | 'auditor'
  passwordHash String
  createdAt    DateTime @default(now())
  resetTokens  PasswordResetToken[]
}

/// Einmalige, kurzlebige Tokens für Self-Service-Passwort-Reset.
/// Es wird nur der SHA-256-Hash des Rohtokens gespeichert.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  id           String   @id @default(cuid())
  name         String
  iban         String?
  type         String   // 'MAIN' | 'GLOBAL_GRANT_TRUST'
  transactions Transaction[]
  createdAt    DateTime @default(now())
}

model ClubYear {
  id                  String   @id @default(cuid())
  label               String   @unique // '2025/2026'
  startsAt            DateTime
  endsAt              DateTime
  /// Schatzmeister hat die Bücher fertig geschlossen (1. Stufe).
  /// Solange `lockedAt` NULL ist, kann der Schatzmeister noch korrigieren.
  isClosed            Boolean  @default(false)
  closedAt            DateTime?
  closedById          String?
  /// Rechnungsprüfer haben das Jahr geprüft (Stufe 2).
  auditedAt           DateTime?
  auditedById         String?
  auditNotes          String?
  /// Mitgliederversammlung hat das Jahr beschlossen → endgültig fixiert (Stufe 3).
  /// Ab hier: ausschließlich lesbar, archiviert.
  lockedAt            DateTime?
  lockedById          String?
  openingBalanceMain  Float    @default(0)
  openingBalanceGG    Float    @default(0)
  transactions Transaction[]
  budgetLines  BudgetLine[]
  cashflows    CashflowEntry[]
  invoices     Invoice[]
  attendanceLists AttendanceList[]
  archivedYear ArchivedYear?
  categories   Category[]
  createdAt    DateTime @default(now())
}

model Category {
  id              String   @id @default(cuid())
  name            String
  kind            String   // INCOME | EXPENSE | NEUTRAL
  color           String   @default("#17458F")
  isDuesCategory  Boolean  @default(false)
  sortOrder       Int      @default(0)
  /// Optional clubyear scope. NULL = global category (verfügbar in allen Clubjahren).
  /// Gesetzt = nur in diesem Clubjahr verfügbar (z. B. Projekt-Kategorien).
  clubYearId      String?
  clubYear        ClubYear? @relation(fields: [clubYearId], references: [id])
  transactions    Transaction[]
  budgetLines     BudgetLine[]
  attendanceLists AttendanceList[]
  /// 1:1 Auto-Kategorie eines Clubprojekts. Wenn gesetzt, ist diese Kategorie
  /// die "Projekt-Kategorie" für genau dieses Projekt – Bank-Buchungen mit
  /// dem Projekt-Code im Verwendungszweck werden automatisch hierhin
  /// zugeordnet.
  project         Project?

  @@unique([clubYearId, name])
}

model Member {
  id             String   @id @default(cuid())
  rotaryMemberId Int?     @unique
  lastName       String
  firstName      String
  salutation     String?
  address        String?
  city           String?
  postalCode     String?
  country        String?
  email          String?
  phone          String?
  paysBySEPA     Boolean  @default(false)
  isExempt       Boolean  @default(false)
  duesAmount     Float    @default(580)
  status         String   @default("ACTIVE") // ACTIVE | INACTIVE | EXEMPT
  joinedAt       DateTime?
  leftAt         DateTime?
  notes          String?
  invoices       Invoice[]
  transactions   Transaction[]
  attendanceEntries AttendanceEntry[]
  allocations    TxAllocation[]
  iban           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([lastName, firstName])
}

model ImportBatch {
  id           String   @id @default(cuid())
  accountId    String
  fileName     String
  importedById String?
  rowCount     Int
  createdAt    DateTime @default(now())
  transactions Transaction[]
}

model Attachment {
  id           String   @id @default(cuid())
  fileName     String
  mimeType     String
  sizeBytes    Int
  /// Vercel-Blob-URL (oder S3-Key, je nach Storage-Adapter).
  storagePath  String
  kind         String   @default("OTHER") // INVOICE | RECEIPT | EMAIL | OTHER
  uploadedById String?
  uploadedAt   DateTime @default(now())
  /// Wenn der Beleg aus einer eingehenden Mail stammt (Postmark-Webhook),
  /// zeigt dies auf den Mail-Datensatz. Dadurch sieht der Prüfer die
  /// Original-Mail (Sender, Betreff, Body, Header).
  mailInboxId  String?
  mailInbox    MailInbox? @relation(fields: [mailInboxId], references: [id])
  /// Legacy-1:1-Relation auf Transaction (wird beim Lesen weiterhin
  /// berücksichtigt, neue Belege gehen über `TransactionAttachment`).
  transactions Transaction[]
  /// M:N Beleg ↔ Buchung (eine Buchung kann mehrere Belege haben,
  /// ein Beleg-PDF kann theoretisch auch mehreren Buchungen anhängen).
  txLinks      TransactionAttachment[]

  @@index([mailInboxId])
}

/// Verknüpfung Transaction ↔ Attachment (Many-to-Many) – ersetzt die
/// alte 1:1-Relation `Transaction.attachmentId`. Legacy-Daten dürfen weiter
/// die alte Spalte verwenden; neue Belege werden hier eingetragen.
model TransactionAttachment {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  attachmentId  String
  attachment    Attachment  @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  /// Quelle der Verknüpfung (manuell hochgeladen, vom Mail-Webhook
  /// automatisch zugeordnet, …).
  source        String      @default("UPLOAD") // UPLOAD | MAIL_AUTO | MAIL_MANUAL
  /// Wer hat den Beleg verknüpft (UserId).
  linkedById    String?
  createdAt     DateTime    @default(now())

  @@unique([transactionId, attachmentId])
  @@index([attachmentId])
}

/// Posteingang für weitergeleitete Rechnungs-Mails (Postmark-Inbound).
/// Eine MailInbox-Zeile entspricht **einer** eingegangenen Mail; sie kann
/// mehrere Anhänge haben (Attachment.mailInboxId) und ggf. einer Buchung
/// zugeordnet sein.
model MailInbox {
  id              String       @id @default(cuid())
  /// Quelle (POSTMARK | UPLOAD | …).
  source          String       @default("POSTMARK")
  /// Absenderadresse (z. B. "rechnung@lieferant.at").
  fromAddress     String
  fromName        String?
  /// To-Adresse (Postmarks Inbound-Adresse, z. B.
  /// "<hash>@inbound.postmarkapp.com").
  toAddress       String?
  subject         String?
  receivedAt      DateTime     @default(now())
  textBody        String?
  htmlBody        String?
  /// RFC-5322 Message-ID, wird zum Deduplizieren genutzt.
  messageId       String?      @unique
  /// Status der Zuordnung.
  status          String       @default("UNMATCHED") // UNMATCHED | MATCHED | DISMISSED
  matchedTxId     String?
  matchedTx       Transaction? @relation("MailMatchedTx", fields: [matchedTxId], references: [id])
  matchedAt       DateTime?
  matchedById     String?
  /// Auto-Match-Konfidenz 0..1, falls von Heuristik gesetzt.
  matchConfidence Float?
  /// Aus Anhängen extrahierter Brutto-Betrag (für Match).
  extractedAmount Float?
  /// Aus Anhängen extrahierte Lieferanten-IBAN.
  extractedIban   String?
  /// Aus Anhängen extrahierte Rechnungs-Nr.
  extractedInvNo  String?
  attachments     Attachment[]
  createdAt       DateTime     @default(now())

  @@index([status])
  @@index([matchedTxId])
}

model Transaction {
  id            String      @id @default(cuid())
  accountId     String
  account       Account     @relation(fields: [accountId], references: [id])
  clubYearId    String
  clubYear      ClubYear    @relation(fields: [clubYearId], references: [id])
  date          DateTime
  valueDate     DateTime?
  counterparty  String?
  purpose       String?
  code          String?
  note          String?
  amount        Float       // positive = income, negative = expense
  categoryId    String?
  category      Category?   @relation(fields: [categoryId], references: [id])
  memberId      String?
  member        Member?     @relation(fields: [memberId], references: [id])
  projectId     String?
  project       Project?    @relation(fields: [projectId], references: [id])
  source        String      @default("MANUAL") // IMPORT | MANUAL | ARCHIVE
  importBatchId String?
  importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id])
  externalRef   String?     // Bank-eigene eindeutige Buchungsreferenz (z. B. George "Buchungsreferenz")
  isReconciled  Boolean     @default(false)
  attachmentId  String?
  attachment    Attachment? @relation(fields: [attachmentId], references: [id])
  attachmentLinks TransactionAttachment[]
  invoicesPaid  Invoice[]   @relation("PaidByTx")
  matchedMails  MailInbox[] @relation("MailMatchedTx")
  allocations   TxAllocation[]
  createdById   String?
  createdAt     DateTime    @default(now())
  deletedAt     DateTime?

  // Bewusst KEIN DB-Unique-Constraint:
  //   - Ein Mitglied kann legitim mehrfach denselben Betrag mit demselben
  //     Verwendungszweck einzahlen (mehrere Mitgliedsbeiträge im Lauf der
  //     Zeit, identische Sammeleinzüge, Refundierung + erneute Buchung).
  //   - George vergibt Quartalsspesen sogar dieselbe Bank-Buchungsreferenz.
  // Duplikat-Erkennung erfolgt deshalb auf Application-Ebene im
  // Bank-Import-Handler (externalRef + Fallback date+amount+purpose +
  // Upgrade-Pfad für seed-importierte Buchungen ohne externalRef).
  @@index([accountId, externalRef])
  @@index([accountId, clubYearId, date])
  @@index([memberId])
  @@index([categoryId])
  @@index([projectId])
}

/// Eigenständiges Clubprojekt (z. B. "RYLA 2026") mit eigener Abrechnung.
/// Buchungen können einem Projekt zugeordnet werden; das Projekt zeigt
/// Einnahmen, Ausgaben und Saldo unabhängig von Konto/Clubjahr.
model Project {
  id           String        @id @default(cuid())
  code         String        @unique         // Kurzcode, z. B. "RYLA26"
  name         String                         // Anzeigename, z. B. "RYLA 2026"
  description  String?
  color        String        @default("#7B2D8E")
  startDate    DateTime?
  endDate      DateTime?
  isClosed     Boolean       @default(false)
  sortOrder    Int           @default(0)
  /// 1:1 verknüpfte Auto-Kategorie. Wird beim Anlegen eines Projekts erzeugt
  /// und bei Namens-/Farb-Änderungen synchronisiert. Buchungen, deren
  /// Verwendungszweck/Gegenpartei den Projekt-Code enthält, werden auf diese
  /// Kategorie + dieses Projekt gesetzt.
  categoryId   String?       @unique
  category     Category?     @relation(fields: [categoryId], references: [id])
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Invoice {
  id                String     @id @default(cuid())
  type              String     // DUES | EXPENSE
  memberId          String
  member            Member     @relation(fields: [memberId], references: [id])
  clubYearId        String
  clubYear          ClubYear   @relation(fields: [clubYearId], references: [id])
  dueDate           DateTime
  amount            Float
  status            String     @default("OPEN") // OPEN | PAID | REMINDED | CANCELLED
  reference         String     @unique
  description       String?
  paymentMethod     String     // SEPA | EMAIL_INVOICE
  reminderLevel     Int        @default(0)
  lastReminderAt    DateTime?
  paidTransactionId String?
  paidTransaction   Transaction? @relation("PaidByTx", fields: [paidTransactionId], references: [id])
  paidAt            DateTime?
  reminderLogs      ReminderLog[]
  attendanceEntry   AttendanceEntry?
  allocations       TxAllocation[]
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([paidTransactionId])
  // Listenseiten /dues filtern stark nach (clubYearId, type, status, dueDate)
  @@index([clubYearId, type, status])
  @@index([clubYearId, type, status, dueDate])
}

/// Buchungs-Aufteilung – z. B. SEPA-Sammeleinzug aufgeteilt auf einzelne
/// Mitgliedsbeiträge / Forderungen. Eine Transaction kann viele Allocations
/// haben; die Summe der Allocation-Beträge sollte = Transaction.amount sein.
model TxAllocation {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  memberId      String?
  member        Member?     @relation(fields: [memberId], references: [id])
  invoiceId     String?
  invoice       Invoice?    @relation(fields: [invoiceId], references: [id])
  amount        Float
  description   String?
  partnerName   String?
  partnerIban   String?
  source        String      @default("SEPA_PDF") // SEPA_PDF | MANUAL
  createdAt     DateTime    @default(now())

  @@index([transactionId])
  @@index([memberId])
  @@index([invoiceId])
}

model ReminderLog {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  sentAt    DateTime @default(now())
  level     Int
  channel   String   @default("EMAIL")
  notes     String?
}

model BudgetLine {
  id         String   @id @default(cuid())
  clubYearId String
  clubYear   ClubYear @relation(fields: [clubYearId], references: [id])
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  amount     Float
  note       String?

  @@unique([clubYearId, categoryId])
}

model CashflowEntry {
  id          String   @id @default(cuid())
  clubYearId  String
  clubYear    ClubYear @relation(fields: [clubYearId], references: [id])
  date        DateTime
  label       String
  amount      Float
  isPlanned   Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
}

model AttendanceList {
  id            String   @id @default(cuid())
  eventName     String
  eventDate     DateTime
  /// Optionale Beschreibung (z. B. "Bus + Hotel + Eintritt") – wird in der
  /// erzeugten Forderungs-Mail mit angegeben.
  description   String?
  totalCost     Float?
  billPerHead   Float
  paymentMethod String   // SEPA | EMAIL_INVOICE | MIXED
  clubYearId    String
  clubYear      ClubYear @relation(fields: [clubYearId], references: [id])
  /// Auto-Kategorie pro Auslagenprojekt – Buchungen (z. B. spätere
  /// Rechnungen) können dem Projekt zugeordnet werden.
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id])
  entries       AttendanceEntry[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
}

model AttendanceEntry {
  id              String   @id @default(cuid())
  listId          String
  list            AttendanceList @relation(fields: [listId], references: [id], onDelete: Cascade)
  memberId        String
  member          Member   @relation(fields: [memberId], references: [id])
  /// Anzahl Personen, für die dieses Mitglied bezahlt (z. B. Mitglied bringt
  /// Familie mit). Forderungsbetrag = personCount × billPerHead, sofern
  /// nicht durch `amount` manuell überschrieben.
  personCount     Int      @default(1)
  amount          Float
  /// Optionale Methoden-Override pro Zeile (z. B. Liste-Default ist MIXED,
  /// Zeile bekommt explizit "EMAIL_INVOICE"). NULL = Listen-Default.
  paymentOverride String?
  invoiceId       String?  @unique
  invoice         Invoice? @relation(fields: [invoiceId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
}

model ArchivedYear {
  id           String   @id @default(cuid())
  clubYearId   String   @unique
  clubYear     ClubYear @relation(fields: [clubYearId], references: [id])
  closedAt     DateTime @default(now())
  closedById   String?
  summaryJson  String   // JSON string
  fileName     String?
}
