# --- Database ---
# Pooled connection (Prisma runtime). Auf Vercel Postgres wird dies via
# „Connect Project" automatisch gesetzt.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require&connect_timeout=15"
# Direkte Verbindung (für Prisma Migrations / db push), ebenfalls
# automatisch von Vercel Postgres gesetzt.
POSTGRES_URL_NON_POOLING="postgresql://user:password@host:5432/dbname?sslmode=require&connect_timeout=15"

# --- NextAuth ---
# In Production zwingend setzen. Lokal: irgendein 32+ Zeichen Random String.
NEXTAUTH_SECRET="change-me-32-bytes-random"
NEXTAUTH_URL="http://localhost:3000"